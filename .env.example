# Copy to .env.local and fill in values. Do not commit .env.local.
# Vercel: Project → Settings → Environment Variables (set per Environment: Production / Preview / Development).

# --- Clerk ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Production custom Frontend API (Clerk Dashboard → Domains). Required for CSP when not using *.accounts.dev.
NEXT_PUBLIC_CLERK_FRONTEND_API_ORIGIN=https://clerk.cgrs.co.nz

# Canonical browser origin (no trailing slash). Local: http://localhost:3000
# Production: https://www.cgrs.co.nz (must match your deployed site URL)
NEXT_PUBLIC_APP_URL=

# Backend API base URL (no trailing slash).
# Local: http://localhost:8000 | Production (Cloud Run): https://cgrs-api-154910431334.australia-southeast1.run.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# Clerk auth page paths (must match Next.js routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register

# Default destination after sign-in / sign-up when Clerk has no redirect_url query param
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# --- Cloudflare Turnstile CAPTCHA ---
# Production keys: https://dash.cloudflare.com/turnstile (add localhost to widget hostnames for local dev).
# Dummy keys for automated tests only (always pass): site key 1x00000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Stadia Maps (community /map basemap) ---
# Optional API key for production quotas: https://client.stadiamaps.com/
# Basemap is Outdoors (terrain + OSM-style roads); homepage map darkens it via CSS (.interactive-map).
NEXT_PUBLIC_STADIA_MAPS_API_KEY=

# --- LINZ Basemaps ---
# Optional API key for LINZ Basemaps raster services: https://basemaps.linz.govt.nz/
NEXT_PUBLIC_LINZ_API_KEY=

# --- LINZ Data Service (LDS) tiles ---
# Separate from Basemaps: create at https://data.linz.govt.nz/ → API Keys (Data access only).
# Used for NZ Property Titles XYZ on tiles-*.data-cdn.linz.govt.nz. Basemaps keys return 403 here.
# Allow your dev/production origins (and localhost) on the key if LDS enforces referrer/domain rules.
NEXT_PUBLIC_LINZ_LDS_API_KEY=
