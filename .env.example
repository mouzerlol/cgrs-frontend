# Copy to .env.local and fill in values. Do not commit .env.local.
# Vercel: Project → Settings → Environment Variables (set per Environment: Production / Preview / Development).

# --- Clerk ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Canonical browser origin (no trailing slash). Local: http://localhost:3000
# Production: https://www.cgrs.co.nz (must match your deployed site URL)
NEXT_PUBLIC_APP_URL=

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=

# Clerk auth page paths (must match Next.js routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register

# Default destination after sign-in / sign-up when Clerk has no redirect_url query param
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# --- Cloudflare Turnstile CAPTCHA ---
# Production keys: https://dash.cloudflare.com/turnstile (add localhost to widget hostnames for local dev).
# Dummy keys for automated tests only (always pass): site key 1x00000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
